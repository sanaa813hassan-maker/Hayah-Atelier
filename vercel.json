{
  "version": 2,
  "builds": [
    {
      "src": "mysite/flask_app.py",
      "use": "@vercel/python"
    },
    {
      "src": "mysite/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/mysite/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "mysite/flask_app.py"
    }
  ]
}
